---

<section class="w-full max-w-6xl mx-auto px-4 py-20">
  <div class="mb-12 text-center">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Certifications</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {
      badges.map((badge) => (
        <a
          href={badge.credlyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative bg-white border border-gray-200 rounded-xl p-6 hover:shadow-xl hover:border-blue-600 hover:-translate-y-1 transition-all duration-300"
        >
          {/* Badge Image */}
          <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-gray-50 border-2 border-gray-100 group-hover:border-blue-600 flex items-center justify-center overflow-hidden transition-all duration-300">
            <img
              src={badge.image}
              alt={badge.name}
              class="w-full h-full object-contain p-2"
              loading="lazy"
            />
          </div>

          {/* Badge Details */}
          <div class="text-center">
            <h3 class="text-sm font-semibold text-gray-900 mb-2 min-h-[40px] flex items-center justify-center leading-tight">
              {badge.name}
            </h3>
            <p class="text-xs text-gray-600 mb-3">{badge.organization}</p>
            <div class="pt-3 border-t border-gray-100">
              <p
                class={`text-xs ${badge.expired ? 'text-red-600 font-medium' : 'text-gray-500'}`}
              >
                {badge.expired ? 'Expired ' : ''}
                {badge.date}
              </p>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  /* Additional custom styles if needed */
  @media (max-width: 768px) {
    .group:hover .opacity-0 {
      opacity: 1; /* Always show verify link on mobile */
    }
  }
</style>
