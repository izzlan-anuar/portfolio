      'https://images.credly.com/size/340x340/images/1e4f7b47-f7e4-47e4-b57e-fdfdde58774b/image.png',
    credlyUrl:
      'https://www.credly.com/badges/e7106370-caf7-4576-9313-7372635c8568',
  },
  {
