    image:
      'https://images.credly.com/size/340x340/images/b3c74474-4d87-4087-8ab8-3f6ec5b4e8b7/2021_Digital_Badges_MicroCredential__Digital_Thinking___Innovation.png',
    credlyUrl:
      'https://www.credly.com/badges/21b57341-69d0-47f9-8c7d-67397585ca14',
  },
  {
    name: 'AWS Academy Graduate - Cloud Foundations',
    organization: 'AWS Training',
    date: 'Oct 2021',
    image:
      'https://images.credly.com/size/340x340/images/e3541a0c-dd4a-4820-8052-5001006efc85/blob',
    credlyUrl:
      'https://www.credly.com/badges/325002d7-0d65-4658-9409-770deb0e14e9',
  },
  {
    name: 'Certified Data Analyst Associate',
    organization: 'Asia Pacific University',
    date: 'Oct 2021',
    image:
      'https://images.credly.com/size/340x340/images/c823a453-c181-469d-a01b-0be377f12ce8/image.png',
    credlyUrl:
      'https://www.credly.com/badges/ccb2459c-8b8d-441a-8479-ec516e5e1824',
  },
  {
    name: 'PCEP – Certified Entry-Level Python Programmer',
    organization: 'Python Institute',
    date: 'Sep 2021',
    image:
      'https://images.credly.com/size/340x340/images/d8017c77-3cc0-4fdf-8e17-62e50632812e/bronze_1_small.png',
    credlyUrl:
      'https://www.credly.com/badges/c7eeceac-f004-4f91-95ca-10de0f071727',
  },
  {
    name: 'Microsoft Certified: Power BI Data Analyst',
    organization: 'Microsoft',
    date: 'Oct 2023',
    image:
      'https://images.credly.com/size/340x340/images/619f60f8-4f63-4772-910e-dc31c6f2f7e8/image.png',
    credlyUrl:
      'https://www.credly.com/badges/290f53e6-ca10-43cd-8d2e-34017afc7cb4',
    expired: true,
  },
